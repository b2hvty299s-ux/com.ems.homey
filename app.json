    "ems-chart": {
      "id": "ems-chart",
      "name": {
        "en": "EMS Today",
        "nl": "EMS Vandaag"
      },
      "height": "large",
      "settings": [],
      "api": {
        "getState": {
          "method": "GET",
          "path": "/getState"
        },
        "getActuals": {
          "method": "GET",
          "path": "/getActuals"
        }
      }
    }
  },
  "api": {
    "getDevices": {
      "method": "GET",
      "path": "/getDevices"
    },
    "getState": {
      "method": "GET",
      "path": "/getState"
    },
    "getPlan": {
      "method": "GET",
      "path": "/getPlan"
    },
    "saveConfig": {
      "method": "POST",
      "path": "/saveConfig"
    },
    "planTrip": {
      "method": "POST",
      "path": "/planTrip"
    },
    "recalculate": {
      "method": "POST",
      "path": "/recalculate"
    },
    "testWallConnector": {
      "method": "POST",
      "path": "/testWallConnector"
    },
    "reloadConfig": {
      "method": "POST",
      "path": "/reloadConfig"
    },
    "getActuals": {
      "method": "GET",
      "path": "/getActuals"
    }
  }
}